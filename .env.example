# ─────────────────────────────────────────────
# AI News — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is in .gitignore.

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ainews

# ─────────────────────────────────────────────
# Auth — Clerk
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# AI & Translation
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
DEEPL_API_KEY=

# ─────────────────────────────────────────────
# Payments — Airwallex
# ─────────────────────────────────────────────
AIRWALLEX_API_KEY=
AIRWALLEX_CLIENT_ID=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
NEXT_PUBLIC_AIRWALLEX_ENV=demo
NEXT_PUBLIC_AIRWALLEX_CLIENT_ID=

# ─────────────────────────────────────────────
# WhatsApp — UltraMsg
# ─────────────────────────────────────────────
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
WHATSAPP_RECIPIENT=

# ─────────────────────────────────────────────
# Email — Resend
# ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=AI News <notifications@ainews.app>

# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────
# Social Media Collectors
# ─────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Workers — Python API
# ─────────────────────────────────────────────
WORKERS_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
DIGEST_TIME=08:00
WEEKLY_DIGEST_DAY=monday
WEEKLY_DIGEST_TIME=09:00
MIN_SCORE_ALERT=9.0
MAX_ARTICLES_DIGEST=5
MAX_ARTICLES_WEEKLY=10
COLLECTION_INTERVAL_HOURS=1
MAX_ARTICLE_AGE_HOURS=24

# ─────────────────────────────────────────────
# Monitoring (optional)
# ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────
# Mobile — Expo
# ─────────────────────────────────────────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WEB_URL=http://localhost:3000
